# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# App
VITE_APP_NAME=BARINV Pro
VITE_APP_ENV=development
VITE_APP_VERSION=0.1.0

# Monitoring
VITE_ENABLE_SENTRY=false
VITE_SENTRY_DSN=

# Sync
VITE_SYNC_RETRY_LIMIT=5
VITE_SYNC_STALE_MINUTES=15

# Build-time feature gates
# true = feature is compiled into the bundle
# false = feature is tree-shaken out entirely
# Runtime on/off per org is controlled via feature_flags DB table
VITE_FEATURE_OFFLINE=true
VITE_FEATURE_GUESTLIST=true
VITE_FEATURE_PURCHASING=true
VITE_FEATURE_RECIPES=true
